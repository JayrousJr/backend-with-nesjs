#  app 
NODE_ENV=development
SERVER_URL=0.0.0.0
PORT=3005
API_PREFIX=api

#  database 
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_db

# Email Configuration
MAIL_MAILER=
SMTP_HOST=
SMTP_PORT= 
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_ENCRYPTION=

#  redis 
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

#  jwt 
# minimum 32 characters
JWT_ACCESS_SECRET=change_this_to_a_secure_random_string_min_32_chars
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_this_to_another_secure_random_string_min_32
JWT_REFRESH_EXPIRES_IN=7d

#  cors / throttle 
# comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# kafka 
# comma-separated list of brokers
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=nestjs-graphql-template

#  feature flags
ENABLE_MULTI_TENANCY=false
SWAGGER_ENABLED=true

#  data retention (days, 0 = keep forever)
# soft-deleted rows are hard-purged after this window
RETENTION_SOFT_DELETED_DAYS=30
# raw page views are pruned after this window (daily VisitorStat aggregates are kept)
RETENTION_PAGE_VIEWS_DAYS=90

 #  notifications — email (resend) 
RESEND_API_KEY=
MAIL_FROM=noreply@yourdomain.com

#  notifications — sms (africa's talking) 
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=sandbox

#  notifications — push (firebase) 
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

#  storage 
# local | s3
STORAGE_DRIVER=local
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# leave empty to use AWS default; set for MinIO or Cloudflare R2
AWS_S3_ENDPOINT=

#  observability 
SENTRY_DSN=

#  oauth — google (sign-in disabled unless both id and secret are set)
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3005/api/auth/google/callback
